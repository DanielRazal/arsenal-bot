# football-data.org — register at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# Telegram — create bot via @BotFather, then add it to your channel as admin
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord — create webhook in your channel: Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# Groq — get key at https://console.groq.com (free, no credit card)
GROQ_API_KEY=

# Gemini fallback — get key at https://aistudio.google.com/apikey (optional)
GEMINI_API_KEY=

# Optional overrides
# Where ops/health alerts go (feed dead, API down). Defaults to TELEGRAM_CHAT_ID.
# Set to a private chat id to keep system messages off the public channel.
# ADMIN_CHAT_ID=
ARSENAL_TEAM_ID=57
TIMEZONE=Asia/Jerusalem
MORNING_DIGEST_HOUR=8
LOG_LEVEL=INFO

# Worker toggles — set to false only if delegating that job to GitHub Actions.
# On Render, leave all true so the single always-on process runs everything.
ENABLE_NEWS_POLLER=true
ENABLE_MORNING_DIGEST=true
ENABLE_STANDINGS_ALERT=true
ENABLE_WEEKLY_RECAP=true

# Health server port — Render injects PORT automatically; only set locally if needed.
# PORT=10000
